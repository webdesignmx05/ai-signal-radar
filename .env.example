# Server-side CSV feed used by the Vite development middleware and Vercel Function.
# Paste the Google Sheets "Publish to web" CSV URL for the Public_Signals worksheet.
SHEET_CSV_URL=

# Use sample data locally until the CSV URL is added.
# On Vercel, leave this false and configure SHEET_CSV_URL.
USE_SAMPLE_DATA=true

# Public links displayed in the dashboard. These are safe to expose in browser code.
VITE_RESEARCH_FORM_URL=
VITE_GITHUB_URL=
