# Private Make Custom Webhook URL. Never expose this with a VITE_ prefix.
MAKE_WEBHOOK_URL=

# Published CSV URL for Public_Request_Status_V2.
PUBLIC_REQUEST_STATUS_V2_CSV_URL=

# Published CSV URL for Public_Signals_V2.
PUBLIC_SIGNALS_V2_CSV_URL=

# Use sample records locally until the two V2 CSV URLs are configured.
USE_SAMPLE_DATA=true

# Public GitHub link displayed in the browser.
VITE_GITHUB_URL=https://github.com/webdesignmx05/ai-signal-radar
